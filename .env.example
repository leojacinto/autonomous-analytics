# ServiceNow instance hosting the x_snc_util_da_* scoped app + seed data.
# The generate-and-load.mjs / purge-table.mjs scripts (fluent-app/scripts/)
# read these three vars via ../../.env relative to their own location,
# so this file must be placed at the repo root as `.env` (not committed).
SN_UTIL_SRC_URL=https://your-instance.service-now.com
SN_UTIL_SRC_USER=your-admin-user
SN_UTIL_SRC_PASS=your-password
